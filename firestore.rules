rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Users 컬렉션: 누구나 조회하여 로그인할 수 있어야 함 (초기에는 단순 허용)
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // 2. Routines 컬렉션: 학생은 본인 것만 저장 가능, 선생님은 모두 조회 가능
    match /routines/{routineId} {
      allow read, write: if true;
    }
    
    // 3. Emotions 컬렉션: 학생은 본인 것만 저장 가능, 선생님은 모두 조회 가능
    match /emotions/{emotionId} {
      allow read, write: if true;
    }
    
    // 4. Questions 컬렉션: 학생은 본인 것만 작성 및 조회 가능, 선생님은 모두 조회 및 수정 가능
    match /questions/{questionId} {
      allow read, write: if true;
    }
  }
}
